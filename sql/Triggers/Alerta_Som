CREATE TRIGGER Alerta_Som
AFTER INSERT ON Som
FOR EACH ROW
BEGIN
    DECLARE limite_som DECIMAL(10,00); -- Valor limite definido

    -- Vai buscar o limite de som definido na configuração do jogo atual
    SELECT alerta_som INTO limite_som
    FROM ConfigJogo
    WHERE IDSimulacao = NEW.IDSimulacao LIMIT 1;

    -- Caso o som inserido atinja ou ultrapasse o limite
    IF NEW.Som >= limite_som THEN
        INSERT INTO Mensagens (IDSimulacao, Hora, Sensor, Leitura, TipoAlerta, Msg)
        VALUES (NEW.IDSimulacao, NEW.Hora, 'Som', NEW.Som, 'Alerta de Ruído', 'O nível de som atingiu o limite crítico.');
    END IF;
END$$