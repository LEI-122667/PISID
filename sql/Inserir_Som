DELIMITER $$

CREATE PROCEDURE Inserir_Som(
    IN p_MongoId INT,
    IN p_Hora TIMESTAMP,
    IN p_Som DECIMAL(6,2)
)
BEGIN
    -- Handler para erros técnicos (retorna 0)
    DECLARE EXIT HANDLER FOR SQLEXCEPTION 
    BEGIN
        SELECT 0 AS Result;
    END;

    -- Variáveis de controlo
    DECLARE v_IDSimulacao INT;
    DECLARE v_CountMongo INT;

    -- 1. Verificar se o MongoID é nulo (Dado Inválido)
    IF p_MongoId IS NULL THEN
        SELECT -1 AS Result;

    ELSE
        -- 2. Verificar se o MongoID já existe (Duplicado)
        SELECT COUNT(*) INTO v_CountMongo FROM Som WHERE MongoId = p_MongoId;
        
        IF v_CountMongo > 0 THEN
            SELECT -2 AS Result;
            
        ELSE
            -- 3. Obter Simulação Ativa
            SELECT IDSimulacao INTO v_IDSimulacao 
            FROM Simulacao 
            WHERE Ativo = TRUE 
            LIMIT 1;

            -- 4. Validações de "Dado Inválido" (-1)
            -- - Som não pode ser negativo
            -- - Deve haver uma simulação ativa
            -- - A data não pode ser futura
            IF v_IDSimulacao IS NULL OR p_Som < 0 OR p_Hora > NOW() THEN
                SELECT -1 AS Result;

            ELSE
                -- 5. Tentativa de Inserção
                INSERT INTO Som (IDSimulacao, Hora, Som, MongoId)
                VALUES (v_IDSimulacao, p_Hora, p_Som, p_MongoId);
                
                -- Se chegou aqui sem disparar o Handler, a inserção correu bem
                SELECT 1 AS Result;
            END IF;
        END IF;
    END IF;
END$$

DELIMITER ;
